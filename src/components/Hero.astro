---
interface Badge {
  icon: string;
  text: string;
}

interface CtaButton {
  label: string;
  href: string;
}

interface Props {
  headingLine1: string;
  headingHighlight: string;
  headingLine3: string;
  subtext: string;
  primaryCta: CtaButton;
  secondaryCta: CtaButton;
  badges: Badge[];
}

const {
  headingLine1,
  headingHighlight,
  headingLine3,
  subtext,
  primaryCta,
  secondaryCta,
  badges,
} = Astro.props;
---

<section class="hero">
  <div class="container hero__inner">
    <div class="hero__content">
      <h1 class="hero__heading">
        <span class="hero__heading-line">{headingLine1}</span>
        <span class="hero__heading-highlight">{headingHighlight}</span>
        <span class="hero__heading-line">{headingLine3}</span>
      </h1>
      <p class="hero__subtext">{subtext}</p>
      <div class="hero__ctas">
        <a href={primaryCta.href} class="btn btn--primary">{primaryCta.label}</a>
        <a href={secondaryCta.href} class="btn btn--ghost">{secondaryCta.label} →</a>
      </div>
      <div class="hero__badges">
        {badges.map((badge) => (
          <span class="badge">
            <span class="badge__icon">{badge.icon}</span>
            <span class="badge__text">{badge.text}</span>
          </span>
        ))}
      </div>
    </div>
    <div class="hero__visual">
      <div class="hero__collage">
        <!-- Left: Fellow graduate — spans both rows -->
        <div class="hero__img hero__img--main">
          <img src="/hero-ilm-main.png" alt="ILM Fellow graduate holding qualification certificate" loading="eager" decoding="async" fetchpriority="high" />
        </div>
        <!-- Right top: group meeting with Unlocking Potential banner -->
        <div class="hero__img hero__img--top">
          <img src="/hero-ilm-top.png" alt="ILM leadership team meeting with Unlocking Potential banner" loading="eager" decoding="async" />
        </div>
        <!-- Right bottom: professional studying assignment on laptop -->
        <div class="hero__img hero__img--bottom">
          <img src="/hero-ilm-bottom.png" alt="Professional completing ILM assignment on laptop" loading="lazy" decoding="async" />
        </div>
        <!-- UK flag badge -->
        <div class="hero__flag" aria-label="UK-based service">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 60 40" role="img" aria-hidden="true">
            <rect width="60" height="40" fill="#012169"/>
            <polygon points="0,0 8,0 60,36 60,40 52,40 0,4" fill="white"/>
            <polygon points="52,0 60,0 60,4 8,40 0,40 0,36" fill="white"/>
            <polygon points="0,0 5,0 60,37.3 60,40 55,40 0,2.7" fill="#C8102E"/>
            <polygon points="55,0 60,0 60,2.7 5,40 0,40 0,37.3" fill="#C8102E"/>
            <rect x="0" y="15" width="60" height="10" fill="white"/>
            <rect x="25" y="0" width="10" height="40" fill="white"/>
            <rect x="0" y="17" width="60" height="6" fill="#C8102E"/>
            <rect x="27" y="0" width="6" height="40" fill="#C8102E"/>
          </svg>
          <span>UK-Based Experts</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background-color: var(--color-bg-white);
    padding: 5rem 0 4rem;
    overflow: hidden;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero__heading {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.12;
    color: var(--color-primary);
    display: flex;
    flex-direction: column;
    gap: 0.05em;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .hero__heading-line {
    display: block;
  }

  .hero__heading-highlight {
    display: block;
    color: var(--color-accent);
  }

  .hero__subtext {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    max-width: 520px;
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 2.5rem;
    align-items: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.875rem 2rem;
    border-radius: 0.375rem;
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    transition: background-color 0.2s, color 0.2s, border-color 0.2s;
    border: 2px solid transparent;
    white-space: nowrap;
  }

  .btn--primary {
    background-color: var(--color-accent);
    color: var(--color-white);
    border-color: var(--color-accent);
  }

  .btn--primary:hover {
    background-color: var(--color-accent-dark);
    border-color: var(--color-accent-dark);
  }

  .btn--ghost {
    background-color: transparent;
    color: var(--color-primary);
    border-color: var(--color-border-light);
    font-weight: 500;
  }

  .btn--ghost:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .hero__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    background-color: var(--color-accent-light);
    color: var(--color-primary);
    padding: 0.375rem 0.875rem;
    border-radius: 2rem;
    font-size: 0.8125rem;
    font-weight: 600;
  }

  .badge__icon {
    color: var(--color-accent-dark);
    font-weight: 800;
  }

  /* Collage visual */
  .hero__visual {
    display: flex;
    align-items: stretch;
  }

  .hero__collage {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 0.625rem;
    width: 100%;
    height: 480px;
    border-radius: 1.25rem;
    overflow: hidden;
    box-shadow: 0 16px 56px rgba(20, 83, 45, 0.22);
  }

  .hero__img {
    overflow: hidden;
  }

  .hero__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.4s ease;
  }

  .hero__img:hover img {
    transform: scale(1.04);
  }

  /* Fellow graduate spans both rows on the left */
  .hero__img--main {
    grid-column: 1;
    grid-row: 1 / 3;
  }

  .hero__img--top {
    grid-column: 2;
    grid-row: 1;
  }

  .hero__img--bottom {
    grid-column: 2;
    grid-row: 2;
  }

  /* UK flag badge */
  .hero__flag {
    position: absolute;
    top: 1rem;
    left: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255, 255, 255, 0.95);
    border-radius: 2rem;
    padding: 0.4rem 0.75rem 0.4rem 0.45rem;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
    backdrop-filter: blur(4px);
    z-index: 2;
  }

  .hero__flag svg {
    width: 30px;
    height: 20px;
    border-radius: 3px;
    flex-shrink: 0;
  }

  .hero__flag span {
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--color-primary);
    white-space: nowrap;
  }

  @media (max-width: 900px) {
    .hero__inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .hero__collage {
      height: 320px;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding: 3rem 0 2.5rem;
    }

    .hero__ctas {
      flex-direction: column;
      align-items: stretch;
    }

    .btn {
      width: 100%;
      justify-content: center;
    }

    .hero__collage {
      height: 260px;
      gap: 0.375rem;
    }
  }
</style>
